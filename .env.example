# Public URL of the SvelteKit app (needed for CSRF)
ORIGIN=https://journal.facile.studio

# Legacy shared bearer token for POST /ingest (empty disables it). Prefer
# per-app API keys created from the dashboard's Keys page.
INGEST_TOKEN=

# Days to keep ingested log entries before pruning
RETENTION_DAYS=90

# Allow self-service dashboard registration. First account created becomes admin.
# Set to false to lock sign-ups once your accounts exist (the first account can
# always be created, so you can never lock yourself out).
ALLOW_REGISTRATION=true

# Allowed frontend origins for CORS (comma-separated, optional)
ALLOWED_ORIGINS=

LOG_LEVEL=info
