DOMAINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:5173,http://127.0.0.1:5173

DATABASE_URL=postgres://journal:journal-internal-db@localhost:5432/journal?sslmode=disable
PORT=4010
LOG_LEVEL=info

# Bearer token required to POST /ingest
INGEST_TOKEN=change-me

# Delete log entries older than this many days (hourly job). 0 disables retention.
RETENTION_DAYS=90

# Allow self-service dashboard registration. First account created becomes admin.
# Set to false to lock sign-ups once your accounts exist (the first account can
# always be created, so you can never lock yourself out).
ALLOW_REGISTRATION=true

# Comma-separated hostnames allowed as internal webhook targets for alerts (e.g. nook); external https URLs always work; private/loopback/metadata addresses are blocked unless the host is listed here.
WEBHOOK_ALLOWED_HOSTS=
